# ========================================
# COVENANT SYSTEMS - Environment Variables
# ========================================

# Application
APP_NAME=covenant_systems
APP_ENV=development
DEBUG=True
LOG_LEVEL=INFO

# Database - PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=covenant_db
POSTGRES_USER=covenant_user
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis (for Celery task queue)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# Vector Database - FAISS
VECTOR_DB_PATH=storage/vector_db
VECTOR_INDEX_TYPE=IVFFlat
VECTOR_DIMENSION=384  # sentence-transformers/all-MiniLM-L6-v2

# Embedding Model
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu  # or cuda if GPU available
EMBEDDING_BATCH_SIZE=32

# OCR - Tesseract
TESSERACT_CMD=/usr/local/bin/tesseract
TESSERACT_LANG=eng
OCR_DPI=300
OCR_THRESHOLD_CHARS=50  # If extracted text < 50 chars, trigger OCR
OCR_THRESHOLD_FILESIZE_KB=100

# PDF Processing
PDF_MAX_PAGES=1000
PDF_EXTRACT_IMAGES=False

# Chunking & Segmentation
CHUNK_SIZE=512
CHUNK_OVERLAP=50
SECTION_MIN_LENGTH=20

# Retrieval Settings
RETRIEVAL_TOP_K=10
RETRIEVAL_SCORE_THRESHOLD=0.7
BM25_TOP_K=20
HYBRID_ALPHA=0.5  # 0.5 = equal weight to semantic and lexical

# Reranker
USE_RERANKER=True
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_RELOAD=True

# Storage Paths
BRONZE_PATH=storage/bronze
SILVER_PATH=storage/silver
GOLD_PATH=storage/gold
KG_PATH=storage/knowledge_graph

# Knowledge Graph
KG_NODES_FILE=storage/knowledge_graph/nodes.yaml
KG_EDGES_FILE=storage/knowledge_graph/edges.yaml
KG_DOMAINS_FILE=storage/knowledge_graph/domains.yaml

# Validation & Benchmarking
VALIDATION_PATH=data/validation
BENCHMARK_SUITE=data/validation/benchmarks

# LLM Settings (Optional - for reasoning/evaluation)
# Uncomment and configure if using OpenAI or other LLM providers
# OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4-turbo-preview
# OPENAI_TEMPERATURE=0.1
# OPENAI_MAX_TOKENS=2000

# Anthropic Claude (if using)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Azure OpenAI (if using)
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_api_key_here
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name

# Compliance & Quality
CONFIDENCE_THRESHOLD=0.75
HALLUCINATION_MODE=conservative
PRESERVE_VERBATIM=True